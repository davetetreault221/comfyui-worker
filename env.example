# RabbitMQ Connection
# Local: amqp://guest:guest@localhost:5672/
# CloudAMQP: amqps://user:pass@hostname.cloudamqp.com/vhost
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ComfyUI URL (usually localhost on Lambda Labs)
COMFYUI_URL=http://localhost:8188

# Queue name (must match what FastAPI publishes to)
QUEUE_NAME=comfyui_jobs

# Supabase (optional - for storing results)
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
